{
    "name": "latex-visualizer",
    "displayName": "LaTeX Visualizer",
    "description": "A lightweight live preview for LaTeX prose and formulas.",
    "version": "0.0.1",
    "engines": {
        "vscode": "^1.120.0"
    },
    "categories": [
        "Other"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "latex-visualizer.openPreview",
                "title": "Open LaTeX Preview"
            }
        ],
        "menus": {
            "editor/title": [
                {
                    "command": "latex-visualizer.openPreview",
                    "when": "resourceLangId == latex",
                    "group": "navigation"
                }
            ]
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "sample": "node scripts/check-samples.mjs",
        "pretest": "npm run compile && npm run lint",
        "lint": "eslint src"
    },
    "devDependencies": {
        "@types/mocha": "^10.0.10",
        "@types/node": "22.x",
        "@types/vscode": "^1.120.0",
        "eslint": "^9.39.3",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.56.1"
    },
    "dependencies": {
        "katex": "^0.17.0"
    }
}